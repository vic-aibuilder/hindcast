# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Tavily search API key — verify plan/tier at build time
TAVILY_API_KEY=

# Backend (Railway): comma-separated CORS origins. Set to the Netlify URL in
# production, e.g. https://hindcast.netlify.app. Defaults to the local Vite dev
# server when unset.
ALLOWED_ORIGINS=http://localhost:5173

# Backend DB location. In production point at a persistent volume, e.g.
# /data/hindcast.db. Defaults to ./hindcast.db.
DB_PATH=hindcast.db

# Frontend (Netlify, build-time): backend base URL. Set to the Railway URL,
# e.g. https://hindcast-api.up.railway.app. Defaults to http://localhost:8000.
VITE_API_URL=
